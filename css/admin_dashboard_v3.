/* =====================================
School Connect TN
Admin Dashboard V3 Stable
===================================== */

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f4f6fb;
color:#222;
}

.topBar{
background:#6A1B9A;
color:#fff;
padding:18px;
text-align:center;
box-shadow:0 2px 8px rgba(0,0,0,.2);
}

.topBar .title{
font-size:28px;
font-weight:bold;
}

.topBar .admin{
margin-top:8px;
font-size:18px;
}

.dashboard{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:15px;
padding:20px;
}

.card{
background:#f3e5f5;
border-radius:18px;
padding:25px 15px;
text-align:center;
box-shadow:0 4px 10px rgba(0,0,0,.1);
transition:.3s;
}

.card:hover{
transform:translateY(-5px);
}

.card h1{
font-size:48px;
color:#6A1B9A;
margin-bottom:10px;
}

.card p{
font-size:22px;
font-weight:bold;
}

.menu{
background:#fff;
margin:20px;
padding:20px;
border-radius:18px;
box-shadow:0 4px 12px rgba(0,0,0,.12);
display:flex;
flex-direction:column;
gap:15px;
}

.menu button{
border:none;
border-radius:15px;
padding:18px;
font-size:22px;
background:#6A1B9A;
color:#fff;
cursor:pointer;
transition:.3s;
}

.menu button:hover{
background:#7B1FA2;
}

.menu .logout{
background:#d32f2f;
}

.menu .logout:hover{
background:#b71c1c;
}

footer{
text-align:center;
padding:25px;
font-size:15px;
color:#666;
}

@media(max-width:600px){

.dashboard{
grid-template-columns:repeat(2,1fr);
gap:12px;
padding:15px;
}

.card h1{
font-size:40px;
}

.card p{
font-size:18px;
}

.menu button{
font-size:20px;
padding:16px;
}

}
