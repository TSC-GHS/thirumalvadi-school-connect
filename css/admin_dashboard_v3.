/*=========================================
School Connect TN
Admin Dashboard V3
CSS - Part 1
=========================================*/

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{

background:#F4F7FB;
color:#333;

}

/*=========================
HEADER
=========================*/

.header{

background:linear-gradient(135deg,#1565C0,#0D47A1);

color:#fff;

padding:18px 25px;

display:flex;

justify-content:space-between;

align-items:center;

box-shadow:0 3px 10px rgba(0,0,0,.15);

}

.header-left h2{

font-size:28px;

margin-bottom:5px;

}

.header-left p{

font-size:14px;

opacity:.9;

}

.admin-profile{

background:rgba(255,255,255,.18);

padding:10px 16px;

border-radius:25px;

font-weight:bold;

}

/*=========================
WELCOME CARD
=========================*/

.welcome-card{

margin:20px;

background:#fff;

padding:20px;

border-radius:16px;

box-shadow:0 4px 12px rgba(0,0,0,.08);

}

.welcome-card h2{

color:#1565C0;

margin-bottom:8px;

}

.welcome-card p{

color:#666;

}

/*=========================
SUMMARY
=========================*/

.summary-grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(170px,1fr));

gap:18px;

padding:0 20px 20px;

}

.summary-card{

background:#fff;

padding:22px;

border-radius:16px;

text-align:center;

box-shadow:0 4px 12px rgba(0,0,0,.08);

transition:.3s;

}

.summary-card:hover{

transform:translateY(-5px);

}

.summary-card h3{

font-size:34px;

color:#1565C0;

margin-bottom:10px;

}

.summary-card p{

font-weight:bold;

color:#555;

}
/*=========================================
DASHBOARD CARDS
=========================================*/

.dashboard-card{

margin:20px;

background:#fff;

padding:20px;

border-radius:16px;

box-shadow:0 4px 12px rgba(0,0,0,.08);

}

.dashboard-card h2{

margin-bottom:18px;

color:#1565C0;

}

/*=========================================
QUICK GRID
=========================================*/

.quick-grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(140px,1fr));

gap:15px;

}

.quick-grid button{

background:#1565C0;

color:#fff;

border:none;

border-radius:14px;

padding:18px;

cursor:pointer;

font-size:16px;

font-weight:bold;

display:flex;

flex-direction:column;

align-items:center;

gap:10px;

transition:.3s;

}

.quick-grid button:hover{

background:#0D47A1;

transform:translateY(-4px);

}

/*=========================================
MANAGEMENT GRID
=========================================*/

.management-grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(220px,1fr));

gap:18px;

}

.module-card{

background:#F8FAFD;

border-radius:16px;

padding:20px;

text-decoration:none;

color:#333;

text-align:center;

box-shadow:0 2px 8px rgba(0,0,0,.08);

transition:.3s;

}

.module-card:hover{

transform:translateY(-5px);

background:#E3F2FD;

}

.module-card h3{

margin:12px 0 8px;

color:#1565C0;

}

.module-card p{

font-size:14px;

color:#666;

}

/*=========================================
LOGOUT
=========================================*/

.logoutBtn{

width:100%;

padding:16px;

border:none;

border-radius:12px;

background:#D32F2F;

color:#fff;

font-size:18px;

font-weight:bold;

cursor:pointer;

transition:.3s;

}

.logoutBtn:hover{

background:#B71C1C;

}

/*=========================================
FOOTER
=========================================*/

.footer{

margin-top:30px;

padding:25px;

text-align:center;

background:#0D47A1;

color:#fff;

}

.footer b{

color:#FFD54F;

}

/*=========================================
RESPONSIVE
=========================================*/

@media(max-width:768px){

.header{

flex-direction:column;

text-align:center;

gap:12px;

}

.header-left h2{

font-size:24px;

}

.quick-grid{

grid-template-columns:repeat(2,1fr);

}

.management-grid{

grid-template-columns:1fr;

}

.summary-grid{

grid-template-columns:repeat(2,1fr);

}

}
